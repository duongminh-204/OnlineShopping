@using ASP.BaseCommon
@using ASP.Policies
@using Microsoft.AspNetCore.Authorization
@using ReflectionIT.Mvc.Paging
@inject IAuthorizationService AuthorizationService
@addTagHelper *, ReflectionIT.Mvc.Paging
@model PagingList<ASP.Models.Domains.Category>

@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "../Shared/Layout/Admin/_Layout";
}

<div class="content-wrapper" style="min-height: 422px;">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-12 col-sm-12">
                    <div class="row">
                        <div class="col-md-6 col-sm-6">
                            @if ((await AuthorizationService.AuthorizeAsync(User, new DocumentAuth(), PolicyOperations.ASPCategoriesCreate)).Succeeded)
                            {
                                <a class="btn btn-success add-button" asp-route="admin.categories.create"><i class="fas fa-plus-square"></i> Thêm mới</a>
                            }
                        </div>
                        <div class="col-md-6 col-sm-6">
                            <ol class="breadcrumb float-sm-right">
                                <li class="breadcrumb-item"><a asp-route="admin.dashboard"><i class="fas fa-home"></i> Home</a></li>
                                <li class="breadcrumb-item active">Danh mục</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-lg-12 col-md-12 col-xs-12">
                    <div class="box">
                        <div class="clearfix box-body p-2">
                            <div class="row mb-3">
                                <div class="col-md-12">
                                    <form method="get" class="search-form">
                                        <div class="form-row">
                                            <div class="col-md-4 mb-2">
                                                <label for="searchString">Tìm kiếm</label>
                                                <input type="text" class="form-control" id="searchString" name="searchString" 
                                                       placeholder="Tên danh mục..." 
                                                       value="@Model.RouteValue["searchString"]">
                                            </div>
                                            <div class="col-md-3 mb-2">
                                                <label for="psize">Số bản ghi/trang</label>
                                                <select asp-items="@ASP.BaseCommon.BaseController.BasePageSize()" asp-for="@Model.RouteValue["psize"]" class="form-control" name="psize">
                                                    <option value="">-- Any --</option>
                                                </select>
                                            </div>
                                            <div class="col-md-5 mb-2 d-flex align-items-end">
                                                <button type="submit" class="btn btn-info mr-2">
                                                    <i class="fas fa-search"></i> Tìm kiếm
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>

                            <table class="table table-bordered table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th class="text-center">@Html.SortableHeaderFor(m => m.CategoryId)</th>
                                        <th>@Html.SortableHeaderFor(m => m.CategoryName)</th>
                                        <th class="text-center">Tác vụ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="text-center">@item.CategoryId</td>
                                            <td>@item.CategoryName</td>
                                            <td class="text-center">
                                                @if ((await AuthorizationService.AuthorizeAsync(User, new DocumentAuth(), PolicyOperations.ASPCategoriesUpdate)).Succeeded)
                                                {
                                                    <a asp-route="admin.categories.edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-primary" title="Sửa">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                }
                                                @if ((await AuthorizationService.AuthorizeAsync(User, new DocumentAuth(), PolicyOperations.ASPCategoriesDelete)).Succeeded)
                                                {
                                                    <a onclick="return confirm('Bạn muốn Xóa danh mục này?')" 
                                                       asp-route="admin.categories.delete" asp-route-id="@item.CategoryId" 
                                                       class="btn btn-sm btn-danger" title="Xóa">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>

                            <section class="sct-pagination">
                                <span class="page-count">Trang @Model.PageIndex / @Model.PageCount</span>
                                <span>, &nbsp;&nbsp;Tổng số bản ghi: @Model.TotalRecordCount</span>
                                <div class="pagination pagination-sm m-0 float-right">
                                    <nav aria-label="Categories navigation">
                                        <vc:pager paging-list="@Model" />
                                    </nav>
                                </div>
                            </section>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
    <script type="text/javascript">
        $(function () {
            var connection = new signalR.HubConnectionBuilder()
                .withUrl("/adminHub")
                .configureLogging(signalR.LogLevel.Information)
                .build();

            connection.on("CategoryCreated", function (category) {
                console.log("Category created: " + category.categoryName);
                window.location.reload();
            });

            connection.on("CategoryUpdated", function (category) {
                console.log("Category updated: " + category.categoryName);
                window.location.reload();
            });

            connection.on("CategoryDeleted", function (id) {
                console.log("Category deleted: " + id);
                window.location.reload();
            });

            connection.start().then(function () {
                console.log("Connected to AdminHub successfully (Categories).");
            }).catch(function (err) {
                return console.error("AdminHub connection error: " + err.toString());
            });
        });
    </script>
}
