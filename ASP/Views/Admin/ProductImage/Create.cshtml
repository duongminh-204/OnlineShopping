@{
    ViewData["Title"] = "Upload Image";
    Layout = "../Shared/Layout/Admin/_Layout";
}

<div class="content-wrapper">

    <section class="content-header">
        <h3>Upload Product Image</h3>
    </section>

    <section class="content">

        <div class="card card-primary">
            <div class="card-body">

                <form asp-action="Create"
                      asp-controller="ProductImage"
                      method="post"
                      enctype="multipart/form-data">

                    <input type="hidden" name="productId" value="@ViewBag.ProductId" />

                    <div class="form-group">
                        <label>Image Name</label>
                        <input type="text" name="imageName" class="form-control" placeholder="Enter image name">
                    </div>

                    <div class="form-group">
                        <label>Select Image</label>
                        <input type="file" name="imageFile" class="form-control" />
                    </div>

                    <button class="btn btn-success">
                        Upload
                    </button>

                    <input type="hidden" name="filter" value="@ViewBag.Filter" />
                    <input type="hidden" name="categoryIdSearch" value="@ViewBag.categoryIdSearch" />
                    <input type="hidden" name="page" value="@ViewBag.Page" />

                    <a asp-action="Index"
                       asp-route-productId="@ViewBag.ProductId"
                       class="btn btn-secondary">
                        Back
                    </a>

                </form>

            </div>
        </div>

    </section>

</div>