@model ASP.Models.Domains.ProductVariant
@{
    ViewData["Title"] = "Biến thể sản phẩm - Cập nhật";
    Layout = "../Shared/Layout/Admin/_Layout";
}
<div class="content-wrapper" style="min-height: 422px;">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-sm-12">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-route="admin.productvariants"><i class="fa fa-cubes"></i> Biến thể</a></li>
                        <li class="breadcrumb-item active"> Cập nhật</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
    <section class="content">
        <div class="container-fluid">
            <div class="box box-primary card-body">
                <form autocomplete="off" method="POST" asp-controller="ProductVariant" asp-action="Update" asp-route-id="@Model.VariantId" accept-charset="UTF-8">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="VariantId" />
                    <div class="box-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="ProductId">Sản phẩm</label>
                                    <select asp-for="ProductId" asp-items="@ViewBag.ProductsList" class="form-control select2">
                                        <option value="">-- Chọn sản phẩm --</option>
                                    </select>
                                    <span asp-validation-for="ProductId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="SKU">SKU</label>
                                    <input asp-for="SKU" placeholder="SKU ..." class="form-control" />
                                    <span asp-validation-for="SKU" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Size">Size (Kích thước)</label>
                                    <input asp-for="Size" placeholder="VD: S, M, L, XL..." class="form-control" />
                                    <span asp-validation-for="Size" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Color">Màu sắc</label>
                                    <input asp-for="Color" placeholder="Màu sắc ..." class="form-control" />
                                    <span asp-validation-for="Color" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Price">Giá (Price)</label>
                                    <input asp-for="Price" type="number" step="0.01" class="form-control" value="@Model.Price.ToString("0.00")" />
                                    <span asp-validation-for="Price" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="QuantityVariants">Số lượng trong kho (Stock)</label>
                                    <input asp-for="QuantityVariants" type="number" class="form-control" />
                                    <span asp-validation-for="QuantityVariants" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <div class="custom-control custom-checkbox pt-4">
                                        <input type="checkbox" class="custom-control-input" id="IsActive" asp-for="IsActive">
                                        <label class="custom-control-label" for="IsActive">Kích hoạt</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="box-footer text-right">
                        <a class="btn btn-default" asp-route="admin.productvariants"><i class="fas fa-arrow-circle-left"></i> Quay lại</a>
                        <button class="btn btn-success" type="submit"><i class="fas fa-save"></i> Lưu</button>
                    </div>
                </form>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
    <script type="text/javascript">
        $(function () {
            var connection = new signalR.HubConnectionBuilder()
                .withUrl("/adminHub")
                .configureLogging(signalR.LogLevel.Information)
                .build();

            connection.on("ProductUpdated", function () {
                location.reload();
            });

            connection.start().then(function () {
                console.log("Connected to AdminHub successfully (ProductVariant Edit).");
            }).catch(function (err) {
                return console.error("AdminHub connection error: " + err.toString());
            });
        });
    </script>
}
