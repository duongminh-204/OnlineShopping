@model ASP.Models.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Thêm địa chỉ mới";
    Layout = "~/Views/Shared/Layout/Front/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Thêm địa chỉ giao hàng</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-controller="AddAddress" asp-action="Add" method="post">
                        @* UserId cực kỳ quan trọng để lưu vào DB *@
                        <input type="hidden" asp-for="Address.UserId" />

                        <div class="row">
                            <input type="hidden" asp-for="Address.FullName" class="form-control" />
                            <input type="hidden" asp-for="Address.Phone" class="form-control" />

                            <div class="col-md-4 mb-3">
                                <label asp-for="Address.City" class="form-label fw-bold">Tỉnh/Thành phố</label>
                                <input asp-for="Address.City" class="form-control" />
                                <span asp-validation-for="Address.City" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Address.District" class="form-label fw-bold">Quận/Huyện</label>
                                <input asp-for="Address.District" class="form-control" />
                                <span asp-validation-for="Address.District" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Address.Ward" class="form-label fw-bold">Phường/Xã</label>
                                <input asp-for="Address.Ward" class="form-control" />
                                <span asp-validation-for="Address.Ward" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="Address.AddressLine" class="form-label fw-bold">Địa chỉ chi tiết</label>
                                <textarea asp-for="Address.AddressLine" class="form-control" rows="2"></textarea>
                                <span asp-validation-for="Address.AddressLine" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-4">
                                <div class="form-check form-switch">
                                    <input asp-for="Address.IsDefault" class="form-check-input" type="checkbox">
                                    <label class="form-check-label" asp-for="Address.IsDefault">Đặt làm mặc định</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-controller="Shipping" asp-action="Index" class="btn btn-light">Quay lại</a>
                            <button type="submit" class="btn btn-success px-4">Thêm địa chỉ</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>