@using ASP.Models.Domains
@using ASP.Controllers.Front
@model IEnumerable<Product>
@inject CategoryRepositoryInterface CategoryRepo

@{
    ViewData["Title"] = "Sản phẩm - Fashion Shop";
    Layout = "../Shared/Layout/Front/_Layout";

    var categories = CategoryRepo.GetAllCategories();
    var allProductsUrl = Url.Action("Index", "Product1");
}

<link rel="stylesheet" href="~/css/Product.css" asp-append-version="true" />
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

<div class="container py-5" style="font-family: 'Roboto', sans-serif;">
    <h1 class="text-center mb-5 d-lg-none animate__animated animate__fadeIn">
        <i class="bi bi-bag-heart-fill text-danger me-2"></i>Sản phẩm thời trang
    </h1>

    <!-- Mobile filter button -->
    <div class="d-lg-none mb-4 text-center">
        <button class="btn btn-outline-primary btn-lg px-5"
                type="button"
                data-bs-toggle="offcanvas"
                data-bs-target="#categorySidebar">
            <i class="bi bi-filter-left me-2"></i>Lọc theo danh mục
        </button>
    </div>

    <div class="row g-4">
        <!-- Sidebar (shared logic for mobile & desktop) -->
        <div class="col-lg-3">
            <!-- Mobile offcanvas -->
            <div class="offcanvas offcanvas-start" tabindex="-1" id="categorySidebar">
                <div class="offcanvas-header border-bottom bg-dark text-white">
                    <h5 class="offcanvas-title">
                        <i class="bi bi-tags me-2"></i>Danh mục
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
                </div>
                <div class="offcanvas-body px-0">
                    @await Html.PartialAsync(
                    "~/Views/Front/Products/_CategoryList.cshtml",
                                        categories,
                                        new ViewDataDictionary(ViewData)
                                        {
                                            ["AllUrl"] = allProductsUrl
                                        }
                                        )
                </div>
            </div>

            <!-- Desktop sticky sidebar -->
            <div class="d-none d-lg-block position-sticky top-80">
                <div class="card shadow-sm rounded-4 border-0">
                    <div class="card-header bg-dark text-white">
                        <i class="bi bi-tags me-2"></i>Danh mục
                    </div>
                    @await Html.PartialAsync(
                                        "~/Views/Front/Products/_CategoryList.cshtml",
                                        categories,
                                        new ViewDataDictionary(ViewData)
                                        {
                                            ["AllUrl"] = allProductsUrl
                                        }
                                        )
                </div>
            </div>
        </div>

        <!-- Product grid -->
        <div class="col-lg-9">
            <!-- Product filter -->
            <form method="get" asp-controller="Product1" asp-action="Index" class="mb-4">
                <div class="card shadow-sm rounded-4 border-0">
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label fw-semibold">Tìm kiếm</label>
                                <input type="text"
                                       name="keyword"
                                       value="@ViewBag.Keyword"
                                       class="form-control"
                                       placeholder="Tên sản phẩm hoặc từ khóa..." />
                            </div>

                            <div class="col-md-2">
                                <label class="form-label fw-semibold">Size</label>
                                <select name="size" class="form-select">
                                    <option value="">Tất cả size</option>
                                    @foreach (var item in (List<string>)ViewBag.SizeOptions ?? new List<string>())
                                    {
                                        if ((string?)ViewBag.SelectedSize == item)
                                        {
                                            <option value="@item" selected>@item</option>
                                        }
                                        else
                                        {
                                            <option value="@item">@item</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="col-md-2">
                                <label class="form-label fw-semibold">Màu sắc</label>
                                <select name="color" class="form-select">
                                    <option value="">Tất cả màu</option>
                                    @foreach (var item in (List<string>)ViewBag.ColorOptions ?? new List<string>())
                                    {
                                        if ((string?)ViewBag.SelectedColor == item)
                                        {
                                            <option value="@item" selected>@item</option>
                                        }
                                        else
                                        {
                                            <option value="@item">@item</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="col-md-2">
                                <label class="form-label fw-semibold">Giá từ</label>
                                <input type="number"
                                       name="minPrice"
                                       value="@ViewBag.MinPrice"
                                       class="form-control"
                                       min="0"
                                       placeholder="0" />
                            </div>

                            <div class="col-md-2">
                                <label class="form-label fw-semibold">Đến</label>
                                <input type="number"
                                       name="maxPrice"
                                       value="@ViewBag.MaxPrice"
                                       class="form-control"
                                       min="0"
                                       placeholder="1000000" />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label fw-semibold">Sắp xếp</label>
                                <select name="sort" class="form-select">
                                    <option value="">Mặc định</option>
                                    @if ((string?)ViewBag.Sort == "newest")
                                    {
                                        <option value="newest" selected>Mới nhất</option>
                                    }
                                    else
                                    {
                                        <option value="newest">Mới nhất</option>
                                    }

                                    @if ((string?)ViewBag.Sort == "price_asc")
                                    {
                                        <option value="price_asc" selected>Giá tăng dần</option>
                                    }
                                    else
                                    {
                                        <option value="price_asc">Giá tăng dần</option>
                                    }

                                    @if ((string?)ViewBag.Sort == "price_desc")
                                    {
                                        <option value="price_desc" selected>Giá giảm dần</option>
                                    }
                                    else
                                    {
                                        <option value="price_desc">Giá giảm dần</option>
                                    }

                                    @if ((string?)ViewBag.Sort == "popular")
                                    {
                                        <option value="popular" selected>Phổ biến nhất</option>
                                    }
                                    else
                                    {
                                        <option value="popular">Phổ biến nhất</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-3 d-flex align-items-end">
                                <input type="hidden" name="category" value="@ViewBag.SelectedCategory" />
                                <button type="submit" class="btn btn-dark me-2">
                                    <i class="bi bi-search me-1"></i>Áp dụng
                                </button>
                                <a asp-controller="Product1" asp-action="Index" class="btn btn-outline-secondary">
                                    Reset
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(ViewBag.Keyword as string)
                        || ViewBag.SelectedCategory != null
                        || !string.IsNullOrWhiteSpace(ViewBag.SelectedSize as string)
                        || !string.IsNullOrWhiteSpace(ViewBag.SelectedColor as string)
                        || ViewBag.MinPrice != null
                        || ViewBag.MaxPrice != null
                        || !string.IsNullOrWhiteSpace(ViewBag.Sort as string))
            {
                <div class="alert alert-light border rounded-4 mb-4">
                    <strong>Bộ lọc hiện tại:</strong>
                    @if (!string.IsNullOrWhiteSpace(ViewBag.Keyword as string))
                    {
                        <span class="badge bg-dark me-2">Keyword: @ViewBag.Keyword</span>
                    }
                    @if (ViewBag.SelectedCategory != null)
                    {
                        <span class="badge bg-primary me-2">Category: @ViewBag.SelectedCategory</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(ViewBag.SelectedSize as string))
                    {
                        <span class="badge bg-success me-2">Size: @ViewBag.SelectedSize</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(ViewBag.SelectedColor as string))
                    {
                        <span class="badge bg-info text-dark me-2">Color: @ViewBag.SelectedColor</span>
                    }
                    @if (ViewBag.MinPrice != null)
                    {
                        <span class="badge bg-warning text-dark me-2">Min: @ViewBag.MinPrice</span>
                    }
                    @if (ViewBag.MaxPrice != null)
                    {
                        <span class="badge bg-warning text-dark me-2">Max: @ViewBag.MaxPrice</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(ViewBag.Sort as string))
                    {
                        <span class="badge bg-secondary me-2">Sort: @ViewBag.Sort</span>
                    }
                </div>
            }

            @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
            {
                <div class="col-12 mb-5">
                    <div class="admin-import-wrapper p-4 border-0 shadow-sm rounded-4" style="background-color: #f8f9fa; border: 1px dashed #ced4da !important;">
                        <div class="row align-items-center">
                            <div class="col-md-5">
                               
                                <p class="text-muted small mb-md-0">Import sản phẩm , DownLoad TeamPlate Import <a href="@Url.Action("DownloadTemplate", "Product1")" class="text-primary fw-bold text-decoration-none"></a></p>
                            </div>
                            <div class="col-md-7 text-end">
                                <form asp-action="ImportProductsFromFile" asp-controller="Product1" method="post" enctype="multipart/form-data">
                                    <div class="input-group">
                                        <input type="file" name="file" class="form-control border-dark-subtle shadow-none" accept=".xlsx, .xls" required>
                                        <button class="btn btn-dark px-4 fw-medium" type="submit" style="background-color: #000; border-color: #000;">
                                            <i class="bi bi-file-earmark-arrow-up me-2"></i>Import
                                        </button>
                                        <a href="@Url.Action("DownloadTemplate", "Product1")" class="btn btn-outline-dark px-3" title="Tải file mẫu">
                                            <i class="bi bi-download"></i>
                                        </a>
                                        <a href="@Url.Action("ExportProductsToExcel", "Product1")" class="btn btn-success px-3" title="Xuất dữ liệu Excel">
                                            <i class="bi bi-download me-1"></i> Export
                                        </a>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* Hiển thị thông báo kết quả *@
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-4 mb-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-4 mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (!Model.Any())
            {
                <div class="alert alert-info text-center py-5 rounded-4 shadow-sm">
                    <i class="bi bi-bag-x fs-1 mb-3 d-block"></i>
                    <h4>Chưa có sản phẩm nào</h4>
                </div>
            }
            else
            {
                <div class="card shadow-sm rounded-4 border-0 overflow-hidden">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0"><i class="bi bi-table me-2"></i>Danh sách sản phẩm</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover table-striped mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="width: 80px;">#</th>
                                    <th style="width: 100px;">Ảnh</th>
                                    <th>Tên sản phẩm</th>
                                    <th>Danh mục</th>
                                    <th class="text-end">Giá</th>
                                    <th class="text-center">Size / Màu</th>
                                    <th class="text-center">Trạng thái</th>
                                    <th class="text-center" style="width: 150px;">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int stt = 0;
                                }
                                @foreach (var product in Model)
                                {
                                    stt++;
                                    var activeVariants = product.ProductVariants?
                                        .Where(v => v.IsActive)
                                        .OrderBy(v => v.VariantId)
                                        .ToList();

                                    var price = activeVariants?.FirstOrDefault()?.Price ?? 0m;
                                    var mainImg = product.ProductImages?.FirstOrDefault(x => x.IsMain)
                                        ?? product.ProductImages?.FirstOrDefault();
                                    var imgUrl = mainImg?.ImageUrl ?? "/images/no-image.jpg";
                                    var sizes = activeVariants?.Select(v => v.Size).Distinct().ToList();
                                    var colors = activeVariants?.Select(v => v.Color).Distinct().ToList();
                                    var isActive = product.IsActive;
                                    var hasStock = activeVariants?.Any(v => v.QuantityVariants > 0) ?? false;
                                    <tr>
                                        <td class="text-center fw-semibold">@product.ProductId</td>
                                        <td>
                                            <img src="@imgUrl"
                                                 alt="@product.ProductName"
                                                 class="rounded"
                                                 style="width: 70px; height: 70px; object-fit: cover;">
                                        </td>
                                        <td>
                                            <a asp-action="Details" asp-controller="Product1" asp-route-id="@product.ProductId"
                                               class="text-decoration-none fw-semibold text-dark">
                                                @product.ProductName
                                            </a>
                                            @if (!string.IsNullOrEmpty(product.Description) && product.Description.Length > 50)
                                            {
                                                <br><small class="text-muted">@product.Description.Substring(0, 50)...</small>
                                            }
                                            else if (!string.IsNullOrEmpty(product.Description))
                                            {
                                                <br><small class="text-muted">@product.Description</small>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">@product.Category?.CategoryName</span>
                                        </td>
                                        <td class="text-end fw-semibold text-danger">
                                            @if (price > 0)
                                            {
                                                @price.ToString("N0") <small>đ</small>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Liên hệ</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex flex-wrap justify-content-center gap-1">
                                                @if (sizes != null && sizes.Any())
                                                {
                                                    @foreach (var size in sizes.Take(3))
                                                    {
                                                        <span class="badge bg-primary">@size</span>
                                                    }
                                                    @if (sizes.Count > 3)
                                                    {
                                                        <span class="badge bg-secondary">+@(sizes.Count - 3)</span>
                                                    }
                                                }
                                            </div>
                                            <div class="d-flex flex-wrap justify-content-center gap-1 mt-1">
                                                @if (colors != null && colors.Any())
                                                {
                                                    @foreach (var color in colors.Take(3))
                                                    {
                                                        <span class="badge bg-info text-dark">@color</span>
                                                    }
                                                    @if (colors.Count > 3)
                                                    {
                                                        <span class="badge bg-secondary">+@(colors.Count - 3)</span>
                                                    }
                                                }
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            @if (isActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Inactive</span>
                                            }
                                            @if (hasStock)
                                            {
                                                <br><small class="text-success"><i class="bi bi-check-circle me-1"></i>Còn hàng</small>
                                            }
                                            else
                                            {
                                                <br><small class="text-danger"><i class="bi bi-x-circle me-1"></i>Hết hàng</small>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <a asp-action="Details" asp-controller="Product1" asp-route-id="@product.ProductId"
                                                   class="btn btn-outline-primary" title="Xem chi tiết">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                                                {
                                                    <a asp-action="Edit" asp-controller="Product" asp-route-id="@product.ProductId"
                                                       class="btn btn-outline-warning" title="Sửa">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <a asp-controller="ProductImage" asp-action="Index" asp-route-productId="@product.ProductId"
                                                       class="btn btn-outline-info" title="Hình ảnh">
                                                        <i class="bi bi-image"></i>
                                                    </a>
                                                    <a asp-controller="ProductVariant" asp-action="Index" asp-route-productId="@product.ProductId"
                                                       class="btn btn-outline-dark" title="Biến thể">
                                                        <i class="bi bi-box-seam"></i>
                                                    </a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>

    @if ((int)ViewBag.TotalPages > 1)
    {
        <nav class="mt-5">
            <ul class="pagination justify-content-center">

                <li class="page-item @((int)ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-controller="Product1"
                       asp-route-page="@((int)ViewBag.CurrentPage - 1)"
                       asp-route-keyword="@ViewBag.Keyword"
                       asp-route-category="@ViewBag.SelectedCategory"
                       asp-route-size="@ViewBag.SelectedSize"
                       asp-route-color="@ViewBag.SelectedColor"
                       asp-route-minPrice="@ViewBag.MinPrice"
                       asp-route-maxPrice="@ViewBag.MaxPrice"
                       asp-route-sort="@ViewBag.Sort">
                        «
                    </a>
                </li>

                @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-controller="Product1"
                           asp-route-page="@i"
                           asp-route-keyword="@ViewBag.Keyword"
                           asp-route-category="@ViewBag.SelectedCategory"
                           asp-route-size="@ViewBag.SelectedSize"
                           asp-route-color="@ViewBag.SelectedColor"
                           asp-route-minPrice="@ViewBag.MinPrice"
                           asp-route-maxPrice="@ViewBag.MaxPrice"
                           asp-route-sort="@ViewBag.Sort">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @((int)ViewBag.CurrentPage == (int)ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-controller="Product1"
                       asp-route-page="@((int)ViewBag.CurrentPage + 1)"
                       asp-route-keyword="@ViewBag.Keyword"
                       asp-route-category="@ViewBag.SelectedCategory"
                       asp-route-size="@ViewBag.SelectedSize"
                       asp-route-color="@ViewBag.SelectedColor"
                       asp-route-minPrice="@ViewBag.MinPrice"
                       asp-route-maxPrice="@ViewBag.MaxPrice"
                       asp-route-sort="@ViewBag.Sort">
                        »
                    </a>
                </li>

            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script src="~/lib/signalr/dist/browser/signalr.min.js"></script>

    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/adminHub")
            .build();

        connection.start()
            .then(() => console.log("SignalR connected (Product list)"))
            .catch(err => console.error(err));

        connection.on("ProductUpdated", function (productId) {
            console.log("ProductUpdated:", productId);
            location.reload();
        });
        connection.on("ProductImageUpdated", (productId) => {
            console.log("Product image updated → reload");
            location.reload();
        });

        connection.on("VariantCreated", function (data) {
            console.log("VariantCreated:", data);
            location.reload();
        });

        connection.on("VariantUpdated", function (data) {
            console.log("VariantUpdated:", data);
            location.reload();
        });

        connection.on("VariantUpdated", function (data) {
            console.log("VariantUpdated:", data);
            location.reload();
        });

        connection.on("VariantDeleted", function (variantId, productId) {

            console.log("VariantDeleted:", variantId, productId);

            const row = document.querySelector(`[data-product-id='${productId}']`);

            if (row) {
             console.log("Variant belongs to product in this page → reload");
             location.reload();
             }

        });

    </script>
}