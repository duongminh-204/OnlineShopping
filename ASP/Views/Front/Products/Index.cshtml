@using ASP.Models.Domains
@using ASP.Controllers.Front
@model IEnumerable<Product>
@inject CategoryRepositoryInterface CategoryRepo

@{
    ViewData["Title"] = "Sản phẩm - Fashion Shop";
    Layout = "../Shared/Layout/Front/_Layout";
    var categories = CategoryRepo.GetAllCategories();
}

<link rel="stylesheet" href="~/css/Product.css" />

<!-- Font -->
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<div class="container py-5" style="font-family: 'Roboto', sans-serif;">

    <h1 class="text-center mb-5 d-lg-none animate__animated animate__fadeIn">
        <i class="bi bi-bag-heart-fill text-danger me-2"></i>
        Sản phẩm thời trang
    </h1>

    <!-- Mobile filter -->
    <div class="d-lg-none mb-4 text-center">
        <button class="btn btn-outline-primary btn-lg px-4"
                type="button"
                data-bs-toggle="offcanvas"
                data-bs-target="#categorySidebar">
            <i class="bi bi-filter-left me-2"></i>
            Lọc theo danh mục
        </button>
    </div>

    <div class="row g-4">

        <!-- Sidebar -->
        <div class="col-lg-3">

            <!-- Mobile sidebar -->
            <div class="offcanvas offcanvas-start" tabindex="-1" id="categorySidebar">

                <div class="offcanvas-header border-bottom bg-dark text-white">
                    <h5 class="offcanvas-title">
                        <i class="bi bi-tags me-2"></i>Danh mục
                    </h5>

                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="offcanvas">
                    </button>
                </div>

                <div class="offcanvas-body px-0">

                    <div class="list-group list-group-flush">

                        <a href="@Url.Action("Index","Product")"
                           class="list-group-item list-group-item-action py-3">
                            <i class="bi bi-grid-3x3-gap me-2"></i>
                            Tất cả sản phẩm
                        </a>

                        @foreach (var cat in categories)
                        {
                            <a href="@Url.Action("Index","Product",new {category = cat.CategoryId})"
                               class="list-group-item list-group-item-action py-3">
                                @cat.CategoryName
                            </a>
                        }

                    </div>

                </div>
            </div>

            <!-- Desktop sidebar -->
            <div class="d-none d-lg-block position-sticky top-80">

                <div class="card shadow-sm rounded-4 border-0">

                    <div class="card-header bg-dark text-white">
                        <i class="bi bi-tags me-2"></i>
                        Danh mục
                    </div>

                    <div class="list-group list-group-flush">

                        <a href="@Url.Action("Index","Product")"
                           class="list-group-item list-group-item-action">
                            Tất cả sản phẩm
                        </a>

                        @foreach (var cat in categories)
                        {
                            <a href="@Url.Action("Index","Product",new {category = cat.CategoryId})"
                               class="list-group-item list-group-item-action">
                                @cat.CategoryName
                            </a>
                        }

                    </div>

                </div>

            </div>

        </div>

        <!-- Product list -->
        <div class="col-lg-9">

            @if (!Model.Any())
            {
                <div class="alert alert-info text-center py-5 rounded-4 shadow-sm">
                    <i class="bi bi-bag-x fs-1 mb-3 d-block"></i>
                    <h4>Chưa có sản phẩm</h4>
                </div>
            }
            else
            {

                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4 product-grid">

                    @foreach (var p in Model)
                    {
                        var price = p.ProductVariants?.FirstOrDefault()?.Price ?? 0;
                        var mainImage = p.ProductImages?.FirstOrDefault(x => x.IsMain);
                        var imageUrl = mainImage?.ImageUrl
                        ?? p.ProductImages?.FirstOrDefault()?.ImageUrl
                        ?? "/images/no-image.jpg";

                        <div class="col">

                            <div class="card product-card h-100 border-0 shadow rounded-4">

                                <div class="image-wrapper">

                                    <img src="@imageUrl"
                                         class="card-img-top"
                                         alt="@p.ProductName">

                                    <!-- Hover overlay -->
                                    <div class="image-overlay">

                                        <div class="overlay-buttons">

                                            <!-- View detail -->
                                            <a asp-action="Details"
   asp-controller="Product"
   asp-route-id="@p.ProductId"
   class="icon-btn view-btn"
   title="Xem chi tiết">
    <i class="bi bi-search"></i>
</a>
                                            <!-- Add to cart -->
                                           <a asp-controller="Cart"
   asp-action="AddToCart"
   asp-route-variantId="@p.ProductVariants.FirstOrDefault()?.VariantId"
   class="icon-btn cart-btn"
   title="Thêm vào giỏ">
    <i class="bi bi-bag"></i>
</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body text-center">

                                    <h5 class="card-title product-title">
                                        @p.ProductName
                                    </h5>

                                    <p class="product-price">

                                        @if (price > 0)
                                        {
                                            @price.ToString("N0") <small>đ</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Liên hệ</span>
                                        }
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>