@using ASP.Models.Domains
@using ASP.Controllers.Front
@model IEnumerable<Product>
@inject CategoryRepositoryInterface CategoryRepo
@{
    ViewData["Title"] = "Sản phẩm - Fashion Shop";
    Layout = "../Shared/Layout/Front/_Layout";
    var categories = CategoryRepo.GetAllCategories();
}
<link rel="stylesheet" href="~/css/Product.css" />
<!-- Font Roboto -->
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">

<div class="container py-5" style="font-family: 'Roboto', sans-serif;">
    <h1 class="text-center mb-5 d-lg-none animate__animated animate__fadeIn" style="font-weight: 500;">
        <i class="bi bi-bag-heart-fill text-danger me-2"></i>
        Sản phẩm thời trang
    </h1>

    <!-- Nút mở sidebar mobile -->
    <div class="d-lg-none mb-4 text-center">
        <button class="btn btn-outline-primary btn-lg px-4" type="button" data-bs-toggle="offcanvas" data-bs-target="#categorySidebar">
            <i class="bi bi-filter-left me-2"></i> Lọc theo danh mục
        </button>
    </div>

    <div class="row g-4">
        <!-- Sidebar Categories -->
        <div class="col-lg-3">
            <!-- Offcanvas mobile -->
            <div class="offcanvas offcanvas-start" tabindex="-1" id="categorySidebar" aria-labelledby="categorySidebarLabel">
                <div class="offcanvas-header border-bottom" style="background-color: #000; color: white;">
                    <h5 class="offcanvas-title" id="categorySidebarLabel" style="font-weight: 500;">
                        <i class="bi bi-tags me-2"></i> Danh mục
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
                </div>
                <div class="offcanvas-body px-0" style="background-color: #ffffff;">
                    <div class="list-group list-group-flush">
                        <a href="@Url.Action("Index", "Product")"
                           class="list-group-item list-group-item-action py-3 @(ViewContext.RouteData.Values["category"] == null ? "active" : "")"
                           style="background-color: #ffffff; color: #333;">
                            <i ></i> Tất cả sản phẩm
                        </a>
                        @foreach (var cat in categories)
                        {
                            <a href="@Url.Action("Index", "Product", new { category = cat.CategoryId })"
                               class="list-group-item list-group-item-action py-3 @(ViewContext.RouteData.Values["category"]?.ToString() == cat.CategoryId.ToString() ? "active" : "")"
                               style="background-color: #ffffff; color: #333;">
                                @cat.CategoryName
                            </a>
                        }
                    </div>
                </div>
            </div>

            <!-- Sidebar desktop (sticky) -->
            <div class="d-none d-lg-block position-sticky top-80 pt-2">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-header py-3 text-white" style="background-color: #000; font-weight: 500;">
                        <i class="bi bi-tags me-2"></i> Danh mục
                    </div>
                    <div class="list-group list-group-flush" style="background-color: #ffffff;">
                        <a href="@Url.Action("Index", "Product")"
                           class="list-group-item list-group-item-action py-3 @(ViewContext.RouteData.Values["category"] == null ? "active" : "")"
                           style="color: #333; background-color: #ffffff;">
                            Tất cả sản phẩm
                        </a>
                        @foreach (var cat in categories)
                        {
                            <a href="@Url.Action("Index", "Product", new { category = cat.CategoryId })"
                               class="list-group-item list-group-item-action py-3 @(ViewContext.RouteData.Values["category"]?.ToString() == cat.CategoryId.ToString() ? "active" : "")"
                               style="color: #333; background-color: #ffffff;">
                                @cat.CategoryName
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Product Grid -->
        <div class="col-lg-9">
            @if (!Model.Any())
            {
                <div class="alert alert-info text-center py-5 my-5 rounded-4 shadow-sm animate__animated animate__fadeIn">
                    <i class="bi bi-bag-x fs-1 mb-3 d-block"></i>
                    <h4>Chưa có sản phẩm nào</h4>
                    <p class="text-muted">Vui lòng quay lại sau hoặc thử danh mục khác nhé!</p>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-3 g-4 product-grid animate__animated animate__fadeIn">
                    @foreach (var p in Model)
                    {
                        var price = p.ProductVariants?.FirstOrDefault()?.Price ?? 0;
                        var mainImage = p.ProductImages?.FirstOrDefault(x => x.IsMain);
                        var imageUrl = mainImage?.ImageUrl ?? p.ProductImages?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.jpg";
                        <div class="col product-item animate__animated animate__fadeInUp" style="animation-delay: calc(var(--i) * 80ms);">
                            <div class="card h-100 border-0 shadow overflow-hidden rounded-4 position-relative">
                                <div class="image-wrapper position-relative overflow-hidden">
                                    <img src="@imageUrl" class="card-img-top" alt="@p.ProductName"
                                         style="height: 220px; object-fit: cover; transition: transform 0.6s ease;" />
                                    <div class="image-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center opacity-0 transition-all">
                                        <a asp-action="Details" asp-route-id="@p.ProductId"
                                           class="btn btn-primary btn-lg rounded-pill px-4 shadow-lg">
                                            Xem chi tiết
                                        </a>
                                    </div>
                                </div>
                                <div class="card-body d-flex flex-column text-center p-4">
                                    <h5 class="card-title mb-2 text-truncate-2" style="font-weight: 400;">@p.ProductName</h5>
                                    <p class="fs-4 mb-3 mt-auto" style="color: #000; font-weight: 400;">
                                        @if (price > 0)
                                        {
                                            @price.ToString("N0") <small>đ</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted fs-5">Liên hệ</span>
                                        }
                                    </p>
                                    <a asp-action="Details" asp-route-id="@p.ProductId"
                                       class="btn btn-outline-primary btn-sm rounded-pill mt-2">
                                        Chi tiết <i class="bi bi-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
}